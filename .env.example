# ─── Supabase / PostgreSQL ────────────────────────────────────
# Connection string for Drizzle ORM (use Supabase transaction pooler port 6543)
DATABASE_URL=postgresql://postgres.XXXX:YOUR_PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres

# ─── OpenAI (AI inference) ────────────────────────────────────
OPENAI_API_KEY=sk-...
# Fast, cost-effective model for the chat agent loop. Override if desired.
OPENAI_MODEL=gpt-4.1-mini

# ─── World ID ─────────────────────────────────────────────────
WORLD_APP_ID=app_XXXX
WORLD_ACTION=verify-human
# Legacy v2 Cloud verify endpoint (kept for reference).
WORLD_VERIFY_API_URL=https://developer.world.org/api/v2/verify
# IDKit / World ID 4.0 verify endpoint. /api/verify-proof posts proofs to {URL}/{rp_id}.
WORLD_VERIFY_API_V4_URL=https://developer.world.org/api/v4/verify
WORLD_USERNAME_API_URL=https://usernames.worldcoin.org/api/v1

# ─── Agent / Inference tuning ─────────────────────────────────
MAX_OUTPUT_TOKENS=2048
WINDOW_LIMIT=40

# ─── Auth (NextAuth + World ID RP) ────────────────────────────
AUTH_SECRET=
RP_SIGNING_KEY=
RP_ID=rp_e87d44dbb7b76d91
HMAC_SECRET_KEY=

# ─── World Chain / Financial Ops (server-side) ────────────────
WORLD_CHAIN_RPC_URL=https://worldchain-sepolia.g.alchemy.com/v2/YOUR_KEY
WORLD_CHAIN_TESTNET=true
# The AGENT key — moves user funds on their behalf within on-chain spending limits.
# Keep secret; store as an encrypted env var in Vercel.
RELAYER_PRIVATE_KEY=0x-your-agent-private-key
# Deployed custodial GenieVault address
GENIE_VAULT_ADDRESS=0x-deployed-vault-address
# RE7 USDC ERC-4626 yield vault the GenieVault deposits into
YIELD_VAULT_ADDRESS=0xb1E80387EbE53Ff75a89736097D34dC8D9E9045B
USDC_ADDRESS_TESTNET=0x66145f38cBAC35Ca6F1Dfb4914dF98F1614aeA88
USDC_ADDRESS_MAINNET=0x79A02482A880bCE3F13e09Da970dC34db4CD24d1

# ─── Web / Next.js (NEXT_PUBLIC_ vars are exposed to browser) ─
# Single Vercel deployment — backend routes are same-origin, no external API URL needed.
NEXT_PUBLIC_APP_ID=app_XXXX
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_WORLD_ACTION=verify-human
# World ID network for the IDKit widget: "production" (real Orb users) or
# "staging" (World ID simulator). Defaults to production when unset.
NEXT_PUBLIC_WLD_ENVIRONMENT=production

# ─── Web / Next.js — World Chain (browser-side) ───────────────
NEXT_PUBLIC_WORLD_CHAIN_RPC_URL=https://worldchain-mainnet.g.alchemy.com/public
NEXT_PUBLIC_USDC_ADDRESS=0x79A02482A880bCE3F13e09Da970dC34db4CD24d1
NEXT_PUBLIC_GENIE_VAULT_ADDRESS=0x-deployed-vault-address
